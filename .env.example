# Dev: leave unset to use Vite proxy to the quote engine (default http://127.0.0.1:8080).
# Production / Docker UI: set to your public API origin.
# VITE_API_BASE_URL=https://your-api.example.com

# Override proxy target if the API is not on 8080 (optional).
# VITE_API_PROXY_TARGET=http://127.0.0.1:8080
