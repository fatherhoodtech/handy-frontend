# Dev: leave unset to use Vite proxy to the quote engine (default http://127.0.0.1:8080).
# Production / Docker: set to your public API origin — baked into the bundle at build time.
# VITE_API_BASE_URL=https://handy.us.eqv.rw

# Must match the quote engine host port (Docker Compose publishes 8080 by default).
VITE_API_PROXY_TARGET=http://127.0.0.1:8080
